# Local default (SQLite)
DATABASE_URL=sqlite:///./data/revo.db

# Railway Postgres example (auto-set when you attach a Postgres plugin):
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# Max upload size in MB. 0 = unlimited (default). Every sheet in the workbook is processed.
# MAX_UPLOAD_MB=0

# Protect /api/v1/* — required in production
# API_KEY=change-me

# CORS for external report frontends (* or comma-separated origins)
# CORS_ORIGINS=*
